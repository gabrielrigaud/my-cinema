{
  "name": "my-cinema",
  "version": "1.0.0",
  "description": "Application de gestion de cinéma",
  "scripts": {
    "build:css": "tailwindcss -i ./frontend/css/input.css -o ./frontend/css/output.css",
    "watch:css": "tailwindcss -i ./frontend/css/input.css -o ./frontend/css/output.css --watch",
    "dev": "npm run build:css && concurrently \"npm run watch:css\" \"C:/MAMP/bin/php/php8.3.1/php.exe -S localhost:8000 -t backend\""
  },
  "devDependencies": {
    "tailwindcss": "^3.4.1",
    "concurrently": "^8.2.2"
  }
}
